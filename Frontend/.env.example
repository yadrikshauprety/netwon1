# Main API (Render). Vercel: set these in Project → Environment Variables.
VITE_API_BASE_URL=https://path-to-strength.onrender.com
VITE_BACKEND_URL=https://path-to-strength.onrender.com/api

# Local dev (uncomment and comment production lines above):
# VITE_API_BASE_URL=http://127.0.0.1:5000
# VITE_BACKEND_URL=http://localhost:5000/api

# Optional: only if Peer Connect must hit a different host than VITE_API_BASE_URL (normally same app)
# VITE_CHAUTARA_API_URL=https://path-to-strength.onrender.com/api/chautara

# Copy to .env and add Firebase, Supabase, etc. from your team vault — never commit real .env.
