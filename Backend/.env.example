# MongoDB
MONGODB_URI=mongodb://localhost:27017/sahara
# For production with Supabase PostgreSQL, you'll use a different connection string

# JWT Secrets (use strong random strings in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Firebase (download from Firebase Console)
# Keep serviceAccountKey.json in the src folder (add to .gitignore)
FIREBASE_PROJECT_ID=path-to-strength-9a945
FIREBASE_STORAGE_BUCKET=path-to-strength-9a945.firebasestorage.app

# Frontend origin (merged into CORS allowlist). Match the URL you open in the browser (port matters).
FRONTEND_URL=http://localhost:5173
# Optional extra allowed origins (comma-separated), e.g. https://app.example.com
# CORS_ALLOW_ORIGINS=
# If you use Vite "Network" URL (http://10.x.x.x:8080), enable LAN CORS for private IPs:
# CORS_ALLOW_LAN=1
# main.py sets allow_private_network=True so Chrome’s PNA preflight (localhost → 127.0.0.1) succeeds.

# Server
PORT=5000
NODE_ENV=development

# Email Service (optional - for password reset, email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@sangai.app
